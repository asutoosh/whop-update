# ============================================
# TELEGRAM BOT CONFIGURATION
# ============================================
# Get BOT_TOKEN from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# ============================================
# TELEGRAM USERBOT CONFIGURATION
# ============================================
# Get these from https://my.telegram.org/apps
API_ID=12345678
API_HASH=your_api_hash_here

# Session file name (optional, defaults to "user_forwarder")
USERBOT_SESSION=user_forwarder

# Source channel to monitor (username like @channel or numeric ID)
SOURCE_CHANNEL=@wazirforexalerts

# Destination group/chat ID (must be a supergroup, get from @userinfobot)
FORWARD_TO_CHAT_ID=-1001234567890

# Forum topic/thread ID (optional, only if forwarding to a forum topic)
FORWARD_TO_THREAD_ID=7

# Chat where approval requests are sent (defaults to FORWARD_TO_CHAT_ID)
APPROVAL_CHAT_ID=-1001234567890

# ============================================
# WEBHOOK CONFIGURATION
# ============================================
# Your webhook URL (must be HTTPS unless you set ALLOW_INSECURE_WEBHOOK=true)
WEBHOOK_URL=https://your-webhook-url.com/endpoint

# Optional: Override webhook URL for user_forwarder.py
WHOP_WEBHOOK_URL=https://your-webhook-url.com/endpoint

# How to send data: "json" (default), "form", or "text"
WEBHOOK_SEND_MODE=json

# Field name for the message content (default: "text")
WEBHOOK_PAYLOAD_KEY=text

# Include metadata in webhook payload? (true/false)
WEBHOOK_INCLUDE_META=false

# ============================================
# SECURITY (OPTIONAL BUT RECOMMENDED)
# ============================================
# Shared secret for webhook signing (generate a random string)
# If set, your webhook receiver should validate the X-Webhook-Signature header
# Generate with: openssl rand -hex 32
WEBHOOK_SHARED_SECRET=your_random_secret_string_here

# Custom header name for signature (default: "X-Webhook-Signature")
WEBHOOK_SIGNATURE_HEADER=X-Webhook-Signature

# Allow HTTP webhooks? (ONLY for testing! Set to "true" to allow HTTP)
ALLOW_INSECURE_WEBHOOK=false

# ============================================
# MESSAGE FILTERING
# ============================================
# Only process messages from these chat IDs (comma-separated, leave empty for all)
ALLOWED_CHAT_IDS=

# Only process messages from these topics (format: chat_id:thread_id,chat_id:thread_id)
ALLOWED_TOPICS=

# Only process forwarded messages? (true/false)
REQUIRE_FORWARDED=true

# Include "script" line in formatted output? (true/false)
INCLUDE_SCRIPT_LINE=false

# ============================================
# APPROVAL SYSTEM
# ============================================
# Telegram user IDs allowed to approve forwards (comma-separated)
# Get your user ID from @userinfobot
APPROVER_IDS=123456789

# ============================================
# LOGGING
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
USERBOT_LOG_LEVEL=INFO

